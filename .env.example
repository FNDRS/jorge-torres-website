# Vercel → Project → Storage → Blob: create/link a store (sets BLOB_READ_WRITE_TOKEN on Vercel).
# For local dev: `vercel env pull` or paste the read-write token from the Blob store.
BLOB_READ_WRITE_TOKEN=

# Long random string; same value in Vercel env + pasted in /admin/visuals when uploading.
VISUALS_UPLOAD_SECRET=
