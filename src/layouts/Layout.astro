---
import '../styles/global.css';

const { title = 'Jorge Torres', description = 'Portfolio personal' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased">
    <slot />

    <script>
      (function () {
        var params = new URLSearchParams(window.location.search);
        var ref = params.get('ref');
        if (!ref) return;

        var src = '/ref/' + ref + '.png';
        var img = document.createElement('img');
        img.src = src;
        img.alt = '';
        img.style.position = 'fixed';
        img.style.inset = '0';
        img.style.width = '100%';
        img.style.height = '100%';
        img.style.objectFit = 'cover';
        img.style.pointerEvents = 'none';
        img.style.zIndex = '9999';
        img.style.opacity = '0.35';
        img.style.mixBlendMode = 'normal';
        document.body.appendChild(img);

        var visible = true;
        var opacity = 0.35;

        window.addEventListener('keydown', function (e) {
          if (e.key === 'v') {
            visible = !visible;
            img.style.display = visible ? 'block' : 'none';
          }

          if (e.key === 'o') {
            opacity = Math.min(1, Math.round((opacity + 0.1) * 100) / 100);
            img.style.opacity = String(opacity);
          }

          if (e.key === 'O') {
            opacity = Math.max(0, Math.round((opacity - 0.1) * 100) / 100);
            img.style.opacity = String(opacity);
          }
        });
      })();
    </script>
  </body>
</html>
