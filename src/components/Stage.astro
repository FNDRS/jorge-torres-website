---
type Props = {
  class?: string;
  solid?: boolean;
  backgroundImage?: string;
  backgroundPosition?: string;
  /** When true, vertical content is not clipped (e.g. long galleries); still hides horizontal overflow for layout. */
  scrollable?: boolean;
};

const {
  class: className = '',
  solid = false,
  backgroundImage,
  backgroundPosition = 'center',
  scrollable = false,
} = Astro.props;

const style = backgroundImage
  ? `background-image: url('${backgroundImage}'); background-size: cover; background-position: ${backgroundPosition};`
  : undefined;
---

<section
  class:list={[
    'relative min-h-[calc(100svh-20px)] bg-[#0a0a0a] rounded-[40px] rounded-tr-none transition-all duration-500',
    scrollable ? 'overflow-x-hidden overflow-y-visible' : 'overflow-hidden',
    className,
  ]}
  style={style}
>
  <!-- Notch negro en la esquina superior derecha -->
  <div
    class="absolute top-0 right-0 w-[620px] h-[70px] bg-black rounded-bl-[40px] z-30 animate-fade-in opacity-0"
  >
  </div>

  <!-- Overlay gradient -->
  {
    !solid && (
      <div
        class="absolute inset-0 pointer-events-none z-10 animate-fade-in opacity-0"
        style="background: radial-gradient(1200px 700px at 50% 55%, rgba(0, 0, 0, 0) 40%, rgba(0, 0, 0, 0.6));"
      />
    )
  }

  <slot />
</section>
