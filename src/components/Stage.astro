---
type Props = {
  class?: string;
  solid?: boolean;
  backgroundImage?: string;
  backgroundPosition?: string;
};

const {
  class: className = '',
  solid = false,
  backgroundImage,
  backgroundPosition = 'center',
} = Astro.props;

const style = backgroundImage
  ? `background-image: url('${backgroundImage}'); background-size: cover; background-position: ${backgroundPosition};`
  : undefined;
---

<section
  class:list={[
    'relative min-h-[calc(100svh-10px)] overflow-hidden bg-[#0a0a0a] rounded-bl-[40px]',
    className,
  ]}
  style={style}
>
  <!-- Notch negro en la esquina superior derecha -->
  <div
    class="absolute top-0 right-0 w-[620px] h-[70px] bg-black rounded-bl-[40px] z-30"
  >
  </div>

  <!-- Overlay gradient -->
  {
    !solid && (
      <div
        class="absolute inset-0 pointer-events-none z-10"
        style="background: radial-gradient(1200px 700px at 50% 55%, rgba(0, 0, 0, 0) 40%, rgba(0, 0, 0, 0.6));"
      />
    )
  }

  <slot />
</section>
