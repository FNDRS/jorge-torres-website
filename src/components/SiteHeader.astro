---
import Container from './Container.astro';
import { site } from '../lib/site';
---

<header class="sticky top-0 z-50 border-b border-slate-200/60 bg-white/70 backdrop-blur">
  <Container class="flex h-16 items-center justify-between">
    <a href="#top" class="font-semibold tracking-tight">
      {site.name}
    </a>

    <nav class="hidden items-center gap-6 text-sm text-slate-700 md:flex">
      {
        site.nav.map((item) => (
          <a class="hover:text-slate-950" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm text-slate-800 shadow-sm hover:border-slate-300"
        href={site.social.email}
      >
        Email
      </a>
    </div>
  </Container>
</header>
