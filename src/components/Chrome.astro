---
import { site } from '../lib/site';

const linkClass =
  'inline-flex min-h-[44px] touch-manipulation items-center text-red-600 text-sm tracking-[0.01em] no-underline transition-all duration-300 hover:text-red-500 hover:underline hover:underline-offset-4 sm:text-base';
---

<header
  class="absolute left-0 right-0 top-0 z-40 animate-fade-in opacity-0 pt-[max(0.75rem,env(safe-area-inset-top,0px))] pl-[max(1rem,env(safe-area-inset-left,0px))] pr-[max(1rem,env(safe-area-inset-right,0px))] pb-3 md:py-7 md:pl-9 md:pr-9"
>
  <div class="relative flex flex-col gap-3 md:flex-row md:items-start md:justify-between md:gap-8">
    <a
      class="font-display max-w-full shrink-0 text-[clamp(1.375rem,5.5vw,2rem)] leading-tight tracking-[0.02em] text-white/95 transition-all duration-300 hover:text-white md:text-[32px] md:leading-none"
      href="/"
    >
      {site.name}
    </a>

    <nav
      class="flex max-w-full flex-wrap items-center gap-x-4 gap-y-1 md:absolute md:right-9 md:top-0 md:max-w-none md:flex-nowrap md:justify-end md:gap-x-8 md:gap-y-0 lg:gap-x-10"
      aria-label="Top navigation"
    >
      <a class={linkClass} href={site.social.youtube} target="_blank" rel="noreferrer">YouTube</a>
      <a class={linkClass} href={site.social.instagram} target="_blank" rel="noreferrer">Instagram</a>
      <a class={linkClass} href={site.social.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
    </nav>
  </div>
</header>
