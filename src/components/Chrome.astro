---
import { site } from '../lib/site';
---

<header class="absolute top-0 left-0 right-0 z-40 py-7 px-9 animate-fade-in opacity-0">
  <div class="flex items-start justify-between gap-6">
    <a class="font-display text-[32px] leading-none tracking-[0.02em] text-white/95 transition-all duration-300 hover:text-white" href="/">
      {site.name}
    </a>

    <nav
      class="absolute top-0 right-0 w-[620px] h-[70px] flex items-center justify-center gap-[100px] z-50 pr-10"
      aria-label="Top navigation"
    >
      <a
        class="text-red-600 text-base tracking-[0.01em] no-underline transition-all duration-300 hover:underline hover:underline-offset-4 hover:text-red-500"
        href={site.social.youtube}
        target="_blank"
        rel="noreferrer"
      >
        YouTube
      </a>
      <a
        class="text-red-600 text-base tracking-[0.01em] no-underline transition-all duration-300 hover:underline hover:underline-offset-4 hover:text-red-500"
        href={site.social.instagram}
        target="_blank"
        rel="noreferrer"
      >
        Instagram
      </a>
      <a
        class="text-red-600 text-base tracking-[0.01em] no-underline transition-all duration-300 hover:underline hover:underline-offset-4 hover:text-red-500"
        href={site.social.linkedin}
        target="_blank"
        rel="noreferrer"
      >
        LinkedIn
      </a>
    </nav>
  </div>
</header>
