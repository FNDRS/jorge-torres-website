---
import Layout from '../layouts/Layout.astro';
import Chrome from '../components/Chrome.astro';
import Stage from '../components/Stage.astro';
import PillNav from '../components/PillNav.astro';
import { site } from '../lib/site';
---

<Layout title={`${site.name} - My History`} description={`${site.name} story`}>
  <div class="h-svh overflow-hidden p-[10px]">
    <Chrome />

    <Stage solid class="bg-black h-[calc(100svh-20px)]">
      <PillNav active="history" />
      <div class="relative z-20 flex h-full flex-col justify-center px-24 md:px-40 lg:px-48 xl:px-56">
        <div class="grid items-center gap-12 md:grid-cols-[280px_1fr] md:gap-24 lg:gap-32">
          <div class="flex justify-center md:justify-start animate-fade-in opacity-0">
            <div class="h-[240px] w-[240px] overflow-hidden rounded-full bg-white/10 md:h-[280px] md:w-[280px] transition-transform duration-500 hover:scale-105">
              <img
                src="/media/profile-jorge.png"
                alt="Jorge Torres"
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
          </div>

          <div class="max-w-[680px] animate-fade-in opacity-0 delay-100">
            <h1 class="font-display text-[36px] font-semibold tracking-tight text-white md:text-[42px]">
              My History
            </h1>
            <div class="mt-6 space-y-5 text-[15px] leading-[1.7] text-white/85 md:space-y-6">
              <p class="animate-slide-in opacity-0 delay-200">
                Honduran filmmaker and photographer. Four years building visual stories for brands
                that want to stand out.
              </p>
              <p class="animate-slide-in opacity-0 delay-300">
                I work at the intersection of photography, video, and design — with a constant
                obsession for aesthetics that actually mean something.
              </p>
              <p class="animate-slide-in opacity-0 delay-400">
                I believe every person carries a great story. My work is finding it — and making
                sure it's told the way it deserves to be.
              </p>
            </div>
          </div>
        </div>

        <a
          href="https://www.instagram.com/greathumans.mov"
          target="_blank"
          rel="noreferrer"
          class="mt-12 block rounded-[24px] bg-[#3d3d3d] px-10 py-10 shadow-[0_30px_80px_rgba(0,0,0,0.6)] transition-all duration-300 hover:scale-[1.02] hover:shadow-[0_35px_90px_rgba(0,0,0,0.7)] md:px-14 md:py-12 animate-scale-in opacity-0 delay-400"
        >
          <div class="grid items-center gap-10 md:grid-cols-[1fr_auto_auto] md:gap-16 lg:gap-24">
            <div class="max-w-[420px] space-y-4 text-[14px] leading-[1.7] text-white/85">
              <p>
                In 2025, I founded Great Humans — a production company dedicated to high-end sports
                content.
              </p>
              <p>
                We believe every athlete is already a great human. Our work is proving it.
              </p>
            </div>

            <div class="flex items-center justify-center">
              <img
                src="/media/great-humans-logo.png"
                alt="Great Humans"
                class="h-auto w-[180px] md:w-[220px] lg:w-[260px]"
                loading="lazy"
              />
            </div>

            <div class="flex justify-start md:justify-end">
              <svg
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  d="M16.5 3H7.5C5.01472 3 3 5.01472 3 7.5V16.5C3 18.9853 5.01472 21 7.5 21H16.5C18.9853 21 21 18.9853 21 16.5V7.5C21 5.01472 18.9853 3 16.5 3Z"
                  stroke="white"
                  stroke-width="1.6"></path>
                <path
                  d="M12 16.2C14.3196 16.2 16.2 14.3196 16.2 12C16.2 9.68041 14.3196 7.8 12 7.8C9.68041 7.8 7.8 9.68041 7.8 12C7.8 14.3196 9.68041 16.2 12 16.2Z"
                  stroke="white"
                  stroke-width="1.6"></path>
                <path d="M17.25 6.75H17.26" stroke="white" stroke-width="2.2" stroke-linecap="round"
                ></path>
              </svg>
            </div>
          </div>
        </a>
      </div>
    </Stage>
  </div>
</Layout>
