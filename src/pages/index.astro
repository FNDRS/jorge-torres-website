---
import Layout from '../layouts/Layout.astro';
import Chrome from '../components/Chrome.astro';
import Stage from '../components/Stage.astro';
import PillNav from '../components/PillNav.astro';
import { site } from '../lib/site';
---

<Layout title={site.name} description={`${site.name} - ${site.subtitle}`}>
  <div class="page relative">
    <Chrome />

    <Stage backgroundImage="/media/landing-bg.svg" backgroundPosition="50% 40%">
      <PillNav />
      <div class="relative z-20 flex min-h-[calc(100svh-44px)] items-center justify-center px-6">
        <div class="text-center">
          <h1
            class="font-display text-[88px] font-light leading-[0.95] tracking-[-0.02em] text-white md:text-[132px]"
          >
            {site.name}
          </h1>
          <div class="mx-auto mt-6 h-px w-[520px] max-w-[75vw] bg-white/60"></div>
          <p class="mt-6 text-sm font-semibold tracking-wide text-white/90 md:text-base">
            {site.subtitle}
          </p>
          <p class="mt-3 text-sm font-semibold tracking-wide text-white/80 md:text-base">
            {site.location}
          </p>
        </div>
      </div>
    </Stage>
  </div>
</Layout>
