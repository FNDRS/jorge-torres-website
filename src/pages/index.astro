---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Container from '../components/Container.astro';
import { site } from '../lib/site';
---

<Layout title={`${site.name} - Portfolio`} description={`${site.name} - ${site.role}`}>
  <a id="top" class="sr-only" href="#content">Skip to content</a>
  <SiteHeader />

  <main id="content">
    <section class="relative overflow-hidden py-16 md:py-24">
      <div class="pointer-events-none absolute inset-0">
        <div
          class="absolute -top-24 left-1/2 h-80 w-[42rem] -translate-x-1/2 rounded-full bg-gradient-to-r from-sky-200 via-emerald-200 to-amber-200 opacity-60 blur-3xl"
        >
        </div>
      </div>
      <Container class="relative">
        <p class="text-sm font-medium text-slate-600">{site.location}</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl">
          {site.name}
          <span class="block text-slate-600">{site.role}</span>
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-relaxed text-slate-700 md:text-lg">
          Placeholder copy until we can read the Figma. Once you share/export the design, I will
          match this section pixel-for-pixel.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            class="rounded-full bg-slate-950 px-5 py-2.5 text-sm font-medium text-white hover:bg-slate-900"
            href="#projects"
          >
            View projects
          </a>
          <a
            class="rounded-full border border-slate-200 bg-white px-5 py-2.5 text-sm font-medium text-slate-900 hover:border-slate-300"
            href="#contact"
          >
            Contact
          </a>
        </div>
      </Container>
    </section>

    <section id="about" class="py-14">
      <Container>
        <h2 class="text-xl font-semibold tracking-tight">About</h2>
        <p class="mt-3 max-w-3xl text-slate-700">
          This is a scaffold. The final content, typography, spacing, and colors will be replaced
          once we have access to the Figma frames.
        </p>
      </Container>
    </section>

    <section id="work" class="py-14">
      <Container>
        <h2 class="text-xl font-semibold tracking-tight">Work</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 bg-white p-6">
            <p class="text-sm font-medium text-slate-600">2024 - Present</p>
            <p class="mt-1 text-base font-semibold">Company name</p>
            <p class="mt-2 text-sm text-slate-700">Role and impact (placeholder).</p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white p-6">
            <p class="text-sm font-medium text-slate-600">2022 - 2024</p>
            <p class="mt-1 text-base font-semibold">Company name</p>
            <p class="mt-2 text-sm text-slate-700">Role and impact (placeholder).</p>
          </div>
        </div>
      </Container>
    </section>

    <section id="projects" class="py-14">
      <Container>
        <div class="flex items-end justify-between gap-6">
          <h2 class="text-xl font-semibold tracking-tight">Projects</h2>
          <a
            class="text-sm text-slate-600 hover:text-slate-950"
            href={site.social.github}
            target="_blank"
          >
            All on GitHub
          </a>
        </div>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <a
            class="group rounded-2xl border border-slate-200 bg-white p-6 transition hover:border-slate-300"
            href="#"
          >
            <p class="text-base font-semibold">Project name</p>
            <p class="mt-2 text-sm text-slate-700">
              One-line description. This will be updated from the Figma content.
            </p>
            <p class="mt-4 text-sm font-medium text-slate-900 group-hover:underline">
              View details
            </p>
          </a>
          <a
            class="group rounded-2xl border border-slate-200 bg-white p-6 transition hover:border-slate-300"
            href="#"
          >
            <p class="text-base font-semibold">Project name</p>
            <p class="mt-2 text-sm text-slate-700">One-line description (placeholder).</p>
            <p class="mt-4 text-sm font-medium text-slate-900 group-hover:underline">
              View details
            </p>
          </a>
        </div>
      </Container>
    </section>

    <section id="contact" class="py-14">
      <Container>
        <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8 md:p-10">
          <h2 class="text-xl font-semibold tracking-tight">Contact</h2>
          <p class="mt-3 max-w-2xl text-slate-700">
            If you share the Figma export, I will match this CTA block exactly.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              class="rounded-full bg-slate-950 px-5 py-2.5 text-sm font-medium text-white hover:bg-slate-900"
              href={site.social.email}
            >
              Email me
            </a>
            <a
              class="rounded-full border border-slate-200 bg-white px-5 py-2.5 text-sm font-medium text-slate-900 hover:border-slate-300"
              href={site.social.linkedin}
              target="_blank"
            >
              LinkedIn
            </a>
          </div>
        </div>
      </Container>
    </section>
  </main>

  <SiteFooter />
</Layout>
