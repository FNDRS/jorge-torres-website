---
import Layout from '../layouts/Layout.astro';
import Chrome from '../components/Chrome.astro';
import Stage from '../components/Stage.astro';
import PillNav from '../components/PillNav.astro';
import { site } from '../lib/site';
---

<Layout title={site.name} description={`${site.name} - ${site.subtitle}`}>
  <div class="min-h-svh pl-[10px] pb-[10px]">
    <Chrome />

    <Stage backgroundImage="/media/landing-bg.svg" backgroundPosition="50% 40%">
      <PillNav />
      <div class="relative z-20 flex min-h-svh items-center justify-center px-6">
        <div class="text-center">
          <h1
            class="font-display text-[72px] font-medium leading-[1] tracking-[0.01em] text-white md:text-[96px]"
          >
            {site.name}
          </h1>
          <div class="mx-auto mt-5 h-px w-[480px] max-w-[70vw] bg-white/50"></div>
          <p class="mt-5 text-[13px] font-semibold tracking-[0.03em] text-white/85 md:text-[14px]">
            {site.subtitle}
          </p>
          <p class="mt-2 text-[13px] font-medium tracking-[0.02em] text-white/70 md:text-[14px]">
            {site.location}
          </p>
        </div>
      </div>
    </Stage>
  </div>
</Layout>
