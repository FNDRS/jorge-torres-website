---
import Layout from '../../layouts/Layout.astro';
import Chrome from '../../components/Chrome.astro';
import Stage from '../../components/Stage.astro';
import PillNav from '../../components/PillNav.astro';
import AdminVisualsPanel from '../../components/AdminVisualsPanel';
import { site } from '../../lib/site';
---

<Layout title={`${site.name} - Upload visuals`} description="Upload gallery media to Vercel Blob" noindex>
  <div class="min-h-svh">
    <Chrome />

    <Stage solid class="bg-black" scrollable>
      <PillNav active="visuals" />
      <div class="relative z-20 px-4 pb-32 pt-28 sm:px-6 md:px-8 md:pt-32 lg:px-10">
        <AdminVisualsPanel client:load />
      </div>
    </Stage>
  </div>
</Layout>
